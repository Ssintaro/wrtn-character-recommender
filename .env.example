# 이 파일을 복사해 .env 로 이름을 바꾼 뒤, 본인의 API 키를 채워 넣으세요.
#   Windows:  copy .env.example .env
# .env 파일은 .gitignore 에 등록되어 있어 저장소에 올라가지 않습니다.
# 절대로 이 .env.example 파일에 실제 키 값을 적지 마세요.

# Anthropic API 키 — 추천 멘트 생성 및 의도 파싱(Claude Haiku)에 사용
# 발급: https://console.anthropic.com  → API Keys
ANTHROPIC_API_KEY=

# OpenAI API 키 — 캐릭터/질문 텍스트의 임베딩(text-embedding-3-small)에 사용
# 발급: https://platform.openai.com  → API Keys
OPENAI_API_KEY=
